<UserControl x:Class="BrickByBrick.View.EmployeeDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BrickByBrick.View"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <Style x:Key="ProjectCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="Background" Value="{StaticResource RoleEmployeeBrush}"/>
        </Style>

        <Style x:Key="ProgressTrack" TargetType="Border">
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{StaticResource OutlineBrush}"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!--  HEADER                                                       -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,22">
            <TextBlock Text="My Assigned Projects" Style="{StaticResource HeadlineText}"/>
            <TextBlock Text="Track your active work and post progress updates for clients to see."
                       Style="{StaticResource SubtitleText}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ============================================================ -->
        <!--  QUICK STAT                                                   -->
        <!-- ============================================================ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                Padding="18,14" Margin="0,0,0,18" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"
                HorizontalAlignment="Left">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Color="#1B2A41" Opacity="0.06"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource RoleEmployeeBrush}">
                    <TextBlock Text="🦺" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="12,0,28,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActiveProjectCount}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Active assignments" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!--  MAIN: project list (left) + detail panel (right)            -->
        <!-- ============================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Project list -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding AssignedProjects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ProjectCard}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        <Border Grid.Column="1" Style="{StaticResource StatusPill}" Margin="8,0,0,0">
                                            <TextBlock Text="Active" FontSize="9.5" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Location}" FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>

                                    <Border Style="{StaticResource ProgressTrack}">
                                        <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                                Background="{StaticResource Sdg9OrangeBrush}"
                                                Width="{Binding OverallPercentComplete, Converter={x:Static local:PercentToWidthConverter.Instance}}"/>
                                    </Border>
                                    <TextBlock Text="{Binding OverallPercentComplete, StringFormat='{}{0}% complete'}"
                                               FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Detail panel -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" Padding="28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Direction="270" ShadowDepth="2" Color="#1B2A41" Opacity="0.06"/>
                </Border.Effect>

                <Grid>
                    <!-- Empty state -->
                    <TextBlock Text="Select a project to view details" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasSelectedProject, Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}"/>

                    <!-- Project detail -->
                    <Grid Visibility="{Binding HasSelectedProject, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,18">
                            <TextBlock Text="{Binding SelectedProject.Title}" Style="{StaticResource HeadlineText}" FontSize="20"/>
                            <TextBlock Text="{Binding SelectedProject.Description}" Style="{StaticResource SubtitleText}" Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CLIENT" Style="{StaticResource SectionLabelText}"/>
                                <TextBlock Text="{Binding SelectedProject.SubmittedByClient}" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="LOCATION" Style="{StaticResource SectionLabelText}"/>
                                <TextBlock Text="{Binding SelectedProject.Location}" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PROGRESS" Style="{StaticResource SectionLabelText}"/>
                                <TextBlock Text="{Binding SelectedProject.OverallPercentComplete, StringFormat='{}{0}%'}" FontSize="13"
                                           FontWeight="Bold" Foreground="{StaticResource Sdg9OrangeBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Progress updates feed -->
                        <Border Grid.Row="2" Background="{StaticResource BackgroundBrush}" CornerRadius="10" Padding="16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="PROGRESS LOG" Style="{StaticResource SectionLabelText}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding SelectedProject.ProgressUpdates}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                                        Padding="12,10" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding PostedBy}" FontSize="12"
                                                                       FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding PercentComplete, StringFormat='{}{0}%'}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="{StaticResource Sdg9OrangeBrush}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Note}" FontSize="12.5" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,4"/>
                                                        <TextBlock Text="{Binding PostedOn, StringFormat='MMM d, yyyy — h:mm tt'}"
                                                                   FontSize="10" Foreground="#94A3B8"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Post new update -->
                        <Grid Grid.Row="3" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Text="{Binding NewUpdateNote, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40" Padding="10,8" FontSize="12.5" VerticalContentAlignment="Center"
                                     BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"
                                     Tag="Add a progress update..."/>

                            <ComboBox Grid.Column="1" SelectedValue="{Binding NewUpdatePercent, Mode=TwoWay}"
                                      SelectedValuePath="Tag" Height="40" FontSize="12" VerticalContentAlignment="Center"
                                      Margin="10,0,0,0" BorderBrush="{StaticResource OutlineBrush}">
                                <ComboBoxItem Content="10%" Tag="10"/>
                                <ComboBoxItem Content="25%" Tag="25"/>
                                <ComboBoxItem Content="40%" Tag="40"/>
                                <ComboBoxItem Content="55%" Tag="55"/>
                                <ComboBoxItem Content="70%" Tag="70"/>
                                <ComboBoxItem Content="85%" Tag="85"/>
                                <ComboBoxItem Content="100%" Tag="100"/>
                            </ComboBox>

                            <Button Grid.Column="3" Content="Post Update" Command="{Binding PostUpdateCommand}"
                                    Height="40" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{StaticResource Sdg9OrangeBrush}" CornerRadius="8" Padding="18,0">
                                            <TextBlock Text="Post Update" FontSize="12.5" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="BrickByBrick.View.ClientDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BrickByBrick.View"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <Style x:Key="StatChip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ProposalListCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StatusPillBase" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="9,3"/>
        </Style>

        <Style x:Key="ProgressTrack" TargetType="Border">
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{StaticResource OutlineBrush}"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============================================================ -->
            <!--  HEADER                                                       -->
            <!-- ============================================================ -->
            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="My Projects" Style="{StaticResource HeadlineText}"/>
                    <TextBlock Text="Submit new project proposals and track their progress."
                               Style="{StaticResource SubtitleText}" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding OpenSubmitDialogCommand}"
                        VerticalAlignment="Center" Height="42" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource Sdg9OrangeBrush}" CornerRadius="8" Padding="18,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2"
                                                       Color="#FD6925" Opacity="0.28"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="Submit New Proposal" FontSize="13" FontWeight="Bold" Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.92"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ============================================================ -->
            <!--  STAT CHIPS                                                   -->
            <!-- ============================================================ -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,22">
                <Border Style="{StaticResource StatChip}" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource Sdg9OrangeBrush}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding PendingCount}" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Pending" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatChip}" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource RoleEmployeeBrush}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ApprovedCount}" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Approved" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatChip}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource RoleAdminBrush}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding RejectedCount}" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Rejected" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ============================================================ -->
            <!--  MAIN: proposal list (left) + detail/progress panel (right)  -->
            <!-- ============================================================ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Proposal list -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MyProposals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProposalListCard}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectProposalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>

                                            <Border Grid.Column="1" Margin="8,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource StatusPillBase}">
                                                        <Setter Property="Background" Value="{StaticResource Sdg9OrangeBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                                <Setter Property="Background" Value="{StaticResource RoleEmployeeBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                <Setter Property="Background" Value="{StaticResource RoleAdminBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="9.5" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{Binding Location}" FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                                        <!-- Progress bar only meaningful once approved -->
                                        <StackPanel Visibility="{Binding Status, Converter={x:Static local:StatusToApprovedVisibilityConverter.Instance}}">
                                            <Border Style="{StaticResource ProgressTrack}">
                                                <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                                        Background="{StaticResource RoleEmployeeBrush}"
                                                        Width="{Binding OverallPercentComplete, Converter={x:Static local:PercentToWidthConverter.Instance}}"/>
                                            </Border>
                                            <TextBlock Text="{Binding OverallPercentComplete, StringFormat='{}{0}% complete'}"
                                                       FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Detail panel -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                        BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Direction="270" ShadowDepth="2" Color="#1B2A41" Opacity="0.06"/>
                    </Border.Effect>

                    <Grid>
                        <TextBlock Text="Select a proposal to view details" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding HasSelectedProposal, Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}"/>

                        <Grid Visibility="{Binding HasSelectedProposal, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SelectedProposal.Title}" Style="{StaticResource HeadlineText}" FontSize="20"/>
                                    <TextBlock Text="{Binding SelectedProposal.Description}" Style="{StaticResource SubtitleText}"
                                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" VerticalAlignment="Top">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource StatusPillBase}">
                                            <Setter Property="Background" Value="{StaticResource Sdg9OrangeBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProposal.Status}" Value="Approved">
                                                    <Setter Property="Background" Value="{StaticResource RoleEmployeeBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedProposal.Status}" Value="Rejected">
                                                    <Setter Property="Background" Value="{StaticResource RoleAdminBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SelectedProposal.Status}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="LOCATION" Style="{StaticResource SectionLabelText}"/>
                                    <TextBlock Text="{Binding SelectedProposal.Location}" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="SUBMITTED" Style="{StaticResource SectionLabelText}"/>
                                    <TextBlock Text="{Binding SelectedProposal.SubmittedOn, StringFormat='MMM d, yyyy'}" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Visibility="{Binding SelectedProposal.Status, Converter={x:Static local:StatusToApprovedVisibilityConverter.Instance}}">
                                    <TextBlock Text="PROGRESS" Style="{StaticResource SectionLabelText}"/>
                                    <TextBlock Text="{Binding SelectedProposal.OverallPercentComplete, StringFormat='{}{0}%'}" FontSize="13"
                                               FontWeight="Bold" Foreground="{StaticResource RoleEmployeeBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Progress updates feed — only shown once approved -->
                            <Grid Grid.Row="2">
                                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="10" Padding="16"
                                        Visibility="{Binding SelectedProposal.Status, Converter={x:Static local:StatusToApprovedVisibilityConverter.Instance}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock Text="PROGRESS UPDATES FROM YOUR TEAM" Style="{StaticResource SectionLabelText}" Margin="0,0,0,10"/>
                                            <ItemsControl ItemsSource="{Binding SelectedProposal.ProgressUpdates}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                                                Padding="12,10" Margin="0,0,0,8">
                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding PostedBy}" FontSize="12"
                                                                               FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding PercentComplete, StringFormat='{}{0}%'}"
                                                                               FontSize="11" FontWeight="Bold"
                                                                               Foreground="{StaticResource RoleEmployeeBrush}"/>
                                                                </Grid>
                                                                <TextBlock Text="{Binding Note}" FontSize="12.5" TextWrapping="Wrap"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,4"/>
                                                                <TextBlock Text="{Binding PostedOn, StringFormat='MMM d, yyyy — h:mm tt'}"
                                                                           FontSize="10" Foreground="#94A3B8"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- Pending/Rejected state message -->
                                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="10" Padding="20"
                                        Visibility="{Binding SelectedProposal.Status, Converter={x:Static local:StatusToApprovedVisibilityConverter.Instance}, ConverterParameter=Invert}">
                                    <TextBlock Text="This proposal hasn't been approved yet, so there are no progress updates to show."
                                               FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ============================================================ -->
        <!--  SUBMIT PROPOSAL DIALOG (modal overlay)                       -->
        <!-- ============================================================ -->
        <Grid Visibility="{Binding IsSubmitDialogOpen, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
            <Border Background="#13202F" Opacity="0.45"/>
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="32,28"
                    Width="440" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" Direction="270" ShadowDepth="6" Color="#13202F" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Submit New Proposal" Style="{StaticResource HeadlineText}" FontSize="20"/>
                    <TextBlock Text="Describe your project. A manager will review it shortly."
                               Style="{StaticResource SubtitleText}" Margin="0,4,0,22"/>

                    <TextBlock Text="PROJECT TITLE" Style="{StaticResource SectionLabelText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="8,6" FontSize="13" Margin="0,0,0,16"
                             BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"/>

                    <TextBlock Text="DESCRIPTION" Style="{StaticResource SectionLabelText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                             Height="70" Padding="8,6" FontSize="13" Margin="0,0,0,16"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"/>

                    <TextBlock Text="LOCATION" Style="{StaticResource SectionLabelText}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewLocation, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="8,6" FontSize="13" Margin="0,0,0,26"
                             BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelSubmitCommand}" Height="42" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8"
                                            BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1">
                                        <TextBlock Text="Cancel" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" Content="Submit Proposal" Command="{Binding SubmitProposalCommand}" Height="42" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource Sdg9OrangeBrush}" CornerRadius="8">
                                        <TextBlock Text="Submit Proposal" FontSize="13" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

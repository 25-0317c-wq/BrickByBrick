<UserControl x:Class="BrickByBrick.View.AdminOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,18"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" Direction="270" ShadowDepth="2"
                                       Color="#1B2A41" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoleChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!--  HEADER                                                       -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,22">
            <TextBlock Text="Dashboard" Style="{StaticResource HeadlineText}"/>
            <TextBlock Text="Company-wide overview of projects, people, and system status."
                       Style="{StaticResource SubtitleText}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ============================================================ -->
        <!--  STAT CARDS                                                   -->
        <!-- ============================================================ -->
        <Grid Grid.Row="1" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Active Projects -->
            <Border Grid.Column="0" Style="{StaticResource StatCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource Sdg9OrangeBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ACTIVE PROJECTS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="🏗" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding ActiveProjects}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource Sdg9OrangeBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="across all sites" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Total Users -->
            <Border Grid.Column="2" Style="{StaticResource StatCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource SteelBlueGrayBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TOTAL USERS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="👥" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding TotalUsers}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource SteelNavyBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="across 4 roles" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- System Health -->
            <Border Grid.Column="4" Style="{StaticResource StatCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource RoleEmployeeBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SYSTEM HEALTH" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="✅" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding SystemHealth}" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource RoleEmployeeBrush}" Margin="0,9,0,3"/>
                    <TextBlock Text="all services running" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Open Issues -->
            <Border Grid.Column="6" Style="{StaticResource StatCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource RoleAdminBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OPEN ISSUES" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="⚠" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding OpenIssues}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource RoleAdminBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="needs attention" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================================ -->
        <!--  ROLE BREAKDOWN + RECENT ACTIVITY                             -->
        <!-- ============================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Role breakdown card -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                    Padding="20" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Direction="270" ShadowDepth="2" Color="#1B2A41" Opacity="0.06"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TEAM BY ROLE" Style="{StaticResource SectionLabelText}" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource RoleAdminBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Administrator" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding AdminCount}" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource RoleManagerBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Project Manager" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding ManagerCount}" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource RoleEmployeeBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Field Employee" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding EmployeeCount}" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource RoleClientBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="External Client" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding ClientCount}" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Recent activity feed -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Direction="270" ShadowDepth="2" Color="#1B2A41" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="RECENT ACTIVITY" Style="{StaticResource SectionLabelText}"
                               Margin="20,18,20,10"/>
                    <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="{StaticResource OutlineBrush}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="20,12" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" TextWrapping="Wrap" FontSize="12.5"
                                                       Foreground="{StaticResource TextPrimaryBrush}">
                                                <Run Text="{Binding Actor}" FontWeight="Bold"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Action}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Target}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding TimeAgo}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Top" Margin="14,1,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="BrickByBrick.View.ProgressChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="600">

    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Y-axis labels (0/25/50/75/100) -->
        <Grid Grid.Column="0">
            <TextBlock Text="100" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right"/>
            <TextBlock Text="75" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,52,4,0"/>
            <TextBlock Text="50" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,104,4,0"/>
            <TextBlock Text="25" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,156,4,0"/>
            <TextBlock Text="0" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,4,18"/>
        </Grid>

        <!-- Chart canvas -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
            </Grid.RowDefinitions>

            <Canvas x:Name="ChartCanvas" Grid.Row="0" ClipToBounds="True">
                <!-- Gridlines drawn in code-behind alongside the data line/fill -->
            </Canvas>

            <!-- X-axis date labels -->
            <Canvas x:Name="LabelCanvas" Grid.Row="1"/>
        </Grid>
    </Grid>
</UserControl>

<Window x:Class="BrickByBrick.View.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BrickByBrick.View"
        mc:Ignorable="d"
        Title="BrickByBrick — Create Account" Height="700" Width="900"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="SignUpTextField" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,0,2,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="CaretBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="FieldBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
                                <Setter TargetName="FieldBorder" Property="BorderThickness" Value="0,0,0,2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SignUpPasswordField" TargetType="PasswordBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,0,2,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="CaretBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid>
                            <Border x:Name="FieldBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
                                <Setter TargetName="FieldBorder" Property="BorderThickness" Value="0,0,0,2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SignUpFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SteelBlueGrayBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="CreateAccountButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackToLoginLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL — SDG 9 branding, same as login -->
        <Border Grid.Column="0" Background="{StaticResource SteelNavyBrush}">
            <Grid Margin="48">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                    <Grid Width="64" Height="64" HorizontalAlignment="Left" Margin="0,0,0,28">
                        <Path Data="M8,28 L28,18 L48,28 L48,48 L28,58 L8,48 Z"
                              Fill="{StaticResource Sdg9OrangeBrush}" Opacity="0.95"/>
                        <Path Data="M28,18 L48,8 L64,16 L64,36 L48,28 Z"
                              Fill="{StaticResource Sdg9OrangeDarkBrush}" Opacity="0.85"/>
                        <Path Data="M8,28 L8,8 L28,0 L28,18 Z"
                              Fill="#FF8A52" Opacity="0.9"/>
                    </Grid>

                    <TextBlock Text="BrickByBrick" FontSize="34" FontWeight="Bold"
                               Foreground="White" FontFamily="Segoe UI Semibold"/>
                    <TextBlock Text="Construction Management System" FontSize="14"
                               Foreground="#AEB9C9" Margin="0,4,0,28"/>

                    <Border Background="#22324A" CornerRadius="8" Padding="16" MaxWidth="380"
                            BorderBrush="#33455F" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="JOIN THE TEAM"
                                       FontSize="10" FontWeight="Bold" Foreground="{StaticResource Sdg9OrangeBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Create your account to submit proposals, track projects, or manage your team's work."
                                       FontSize="12" Foreground="#C9D2DE" TextWrapping="Wrap" LineHeight="18"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="System Framework Engine Layer v1.0.0"
                           FontSize="10" Foreground="#5B6B82"/>
            </Grid>
        </Border>

        <!-- RIGHT PANEL — Sign-up form -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14"
                        Padding="40,32" Width="380" Margin="0,30,0,30"
                        BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Style="{StaticResource ElevationCard1}">
                    <StackPanel>

                        <TextBlock Text="Create Account" Style="{StaticResource HeadlineText}"/>
                        <TextBlock Text="Fill in your details to get started" Style="{StaticResource SubtitleText}"
                                   Margin="0,2,0,22"/>

                        <TextBlock Text="FULL NAME" Style="{StaticResource SignUpFieldLabel}"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SignUpTextField}" Margin="0,0,0,16"/>

                        <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource SignUpFieldLabel}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SignUpTextField}" Margin="0,0,0,16"/>

                        <TextBlock Text="PASSWORD" Style="{StaticResource SignUpFieldLabel}"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource SignUpPasswordField}" Margin="0,0,0,16"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>

                        <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource SignUpFieldLabel}"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource SignUpPasswordField}" Margin="0,0,0,16"
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                        <TextBlock Text="I AM A..." Style="{StaticResource SignUpFieldLabel}"/>
                        <ComboBox ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding Role, Mode=TwoWay}"
                                  Height="38" FontSize="13" Padding="8,0,0,0" VerticalContentAlignment="Center"
                                  Margin="0,0,0,22" BorderBrush="{StaticResource OutlineBrush}"/>

                        <!-- Status / error message -->
                        <Border Margin="0,0,0,16" Padding="10,8" CornerRadius="6"
                                Visibility="{Binding HasStatusMessage, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource Sdg9OrangeLightBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStatusError}" Value="False">
                                            <Setter Property="Background" Value="#E3F5EC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="11.5" FontWeight="SemiBold"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SteelNavyBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource RoleAdminBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Button Content="Create Account" Command="{Binding CreateAccountCommand}"
                                Style="{StaticResource CreateAccountButton}"
                                IsEnabled="{Binding IsBusy, Converter={x:Static local:InverseBoolConverter.Instance}}"
                                Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Already have an account?" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Button Content="Sign in" Style="{StaticResource BackToLoginLink}" Margin="6,0,0,0"
                                    Click="BackToLoginButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

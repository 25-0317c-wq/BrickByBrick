<UserControl x:Class="BrickByBrick.View.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BrickByBrick.View"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <!-- Role summary card -->
        <Style x:Key="RoleSummaryCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" Direction="270" ShadowDepth="2"
                                       Color="#1B2A41" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status dot for active/inactive -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
        </Style>

        <!-- Inline role ComboBox -->
        <Style x:Key="RoleComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="UserRow" TargetType="Border">
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFBFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InitialsBadge" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="{StaticResource SteelNavySoftBrush}"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!--  HEADER                                                       -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,22">
            <TextBlock Text="Access &amp; Role Management" Style="{StaticResource HeadlineText}"/>
            <TextBlock Text="Oversee roles and keep every team member at the correct access level."
                       Style="{StaticResource SubtitleText}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ============================================================ -->
        <!--  ROLE SUMMARY CARDS                                           -->
        <!-- ============================================================ -->
        <Grid Grid.Row="1" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Administrator -->
            <Border Grid.Column="0" Style="{StaticResource RoleSummaryCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource RoleAdminBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ADMINISTRATOR" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="🛠" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding AdminCount}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource RoleAdminBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="full system access" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Project Manager -->
            <Border Grid.Column="2" Style="{StaticResource RoleSummaryCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource RoleManagerBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PROJECT MANAGER" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="📐" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding ManagerCount}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource RoleManagerBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="project-level access" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Field Employee -->
            <Border Grid.Column="4" Style="{StaticResource RoleSummaryCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource RoleEmployeeBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FIELD EMPLOYEE" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="🦺" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding EmployeeCount}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource RoleEmployeeBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="task-level access" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- External Client -->
            <Border Grid.Column="6" Style="{StaticResource RoleSummaryCard}" BorderThickness="0,0,0,3"
                    BorderBrush="{StaticResource RoleClientBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="EXTERNAL CLIENT" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="🏗" FontSize="16"/>
                    </Grid>
                    <TextBlock Text="{Binding ClientCount}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource RoleClientBrush}" Margin="0,6,0,0"/>
                    <TextBlock Text="restricted/view-only" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================================ -->
        <!--  USER LIST                                                    -->
        <!-- ============================================================ -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" Direction="270" ShadowDepth="2"
                                   Color="#1B2A41" Opacity="0.06"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List header -->
                <Grid Grid.Row="0" Margin="20,16,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="USER" Style="{StaticResource SectionLabelText}"/>
                    <TextBlock Grid.Column="1" Text="EMAIL" Style="{StaticResource SectionLabelText}"/>
                    <TextBlock Grid.Column="2" Text="DEPARTMENT" Style="{StaticResource SectionLabelText}"/>
                    <TextBlock Grid.Column="3" Text="STATUS" Style="{StaticResource SectionLabelText}" Margin="0,0,24,0"/>
                    <TextBlock Grid.Column="4" Text="ROLE" Style="{StaticResource SectionLabelText}"/>
                </Grid>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="{StaticResource OutlineBrush}"/>

                <!-- List body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Users}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource UserRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="170"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- User: avatar + name -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Style="{StaticResource InitialsBadge}">
                                                <TextBlock Text="{Binding InitialsBadge}" Foreground="White"
                                                           FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding FullName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </StackPanel>

                                        <!-- Email -->
                                        <TextBlock Grid.Column="1" Text="{Binding Email}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Department -->
                                        <TextBlock Grid.Column="2" Text="{Binding Department}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Status -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="0,0,24,0">
                                            <Ellipse Style="{StaticResource StatusDot}" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDot}">
                                                        <Setter Property="Fill" Value="#9CA3AF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource RoleEmployeeBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding IsActive, Converter={x:Static local:BoolToStatusTextConverter.Instance}}"
                                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Inline role dropdown -->
                                        <ComboBox Grid.Column="4" Style="{StaticResource RoleComboBox}"
                                                  ItemsSource="{Binding DataContext.AvailableRoles, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding Role, Mode=TwoWay}">
                                            <ComboBox.Resources>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Padding" Value="8,5"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>

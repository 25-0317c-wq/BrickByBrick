<Window x:Class="BrickByBrick.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BrickByBrick.View"
        mc:Ignorable="d"
        Title="BrickByBrick" Height="640" Width="900"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Material-style underline text field (shared template for username/password) -->
        <Style x:Key="MaterialTextField" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,0,2,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="CaretBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="FieldBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
                                <Setter TargetName="FieldBorder" Property="BorderThickness" Value="0,0,0,2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Same treatment for PasswordBox -->
        <Style x:Key="MaterialPasswordField" TargetType="PasswordBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,0,2,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="CaretBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid>
                            <Border x:Name="FieldBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
                                <Setter TargetName="FieldBorder" Property="BorderThickness" Value="0,0,0,2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Field label above each input -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SteelBlueGrayBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Primary "Sign In" button -->
        <Style x:Key="PrimarySignInButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2"
                                                   Color="#FD6925" Opacity="0.30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary "Sign in with Google" outlined button -->
        <Style x:Key="GoogleSignInButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder" Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1.2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource BackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- "Create an account" link-style button -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Sdg9OrangeBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================ -->
        <!--  LEFT PANEL — SDG 9 "Infrastructure & Innovation" branding   -->
        <!-- ============================================================ -->
        <Border Grid.Column="0" Background="{StaticResource SteelNavyBrush}">
            <Grid Margin="48">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center">

                    <!-- Three connected cubes motif (SDG9 icon language) -->
                    <Grid Width="64" Height="64" HorizontalAlignment="Left" Margin="0,0,0,28">
                        <Path Data="M8,28 L28,18 L48,28 L48,48 L28,58 L8,48 Z"
                              Fill="{StaticResource Sdg9OrangeBrush}" Opacity="0.95"/>
                        <Path Data="M28,18 L48,8 L64,16 L64,36 L48,28 Z"
                              Fill="{StaticResource Sdg9OrangeDarkBrush}" Opacity="0.85"/>
                        <Path Data="M8,28 L8,8 L28,0 L28,18 Z"
                              Fill="#FF8A52" Opacity="0.9"/>
                    </Grid>

                    <TextBlock Text="BrickByBrick" FontSize="34" FontWeight="Bold"
                               Foreground="White" FontFamily="Segoe UI Semibold"/>
                    <TextBlock Text="Construction Management System" FontSize="14"
                               Foreground="#AEB9C9" Margin="0,4,0,28"/>

                    <Border Background="#22324A" CornerRadius="8" Padding="16" MaxWidth="380"
                            BorderBrush="#33455F" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SDG 9 · INDUSTRY, INNOVATION &amp; INFRASTRUCTURE"
                                       FontSize="10" FontWeight="Bold" Foreground="{StaticResource Sdg9OrangeBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Building resilient infrastructure and fostering innovation across every project, one brick at a time."
                                       FontSize="12" Foreground="#C9D2DE" TextWrapping="Wrap" LineHeight="18"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="System Framework Engine Layer v1.0.0"
                           FontSize="10" Foreground="#5B6B82"/>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!--  RIGHT PANEL — Real Sign-in form                              -->
        <!-- ============================================================ -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14"
                    Padding="40,36" Width="380"
                    BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Style="{StaticResource ElevationCard1}">
                <StackPanel>

                    <TextBlock Text="Welcome back" Style="{StaticResource HeadlineText}"/>
                    <TextBlock Text="Sign in to your BrickByBrick account" Style="{StaticResource SubtitleText}"
                               Margin="0,2,0,26"/>

                    <!-- Username -->
                    <TextBlock Text="USERNAME OR EMAIL" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="UsernameTextBox" Style="{StaticResource MaterialTextField}" Margin="0,0,0,18"/>

                    <!-- Password -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Grid.Column="1" Text="Forgot password?" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Sdg9OrangeBrush}" Cursor="Hand"/>
                    </Grid>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource MaterialPasswordField}" Margin="0,0,0,22"/>

                    <!-- Sign in button -->
                    <Button x:Name="SignInButton" Content="Sign In" Style="{StaticResource PrimarySignInButton}"
                            Margin="0,0,0,12" Click="SignInButton_Click"/>

                    <!-- Inline login error message (hidden until a failed attempt) -->
                    <TextBlock x:Name="LoginErrorText" Text="Incorrect email or password. Please try again."
                               FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource RoleAdminBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

                    <!-- Divider -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Separator Grid.Column="0" Background="{StaticResource OutlineBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="OR" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="10,0"/>
                        <Separator Grid.Column="2" Background="{StaticResource OutlineBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Google sign-in -->
                    <Button Style="{StaticResource GoogleSignInButton}" Margin="0,0,0,22">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="G" FontSize="15" FontWeight="Bold" Foreground="#4285F4" Margin="0,0,8,0"/>
                            <TextBlock Text="Sign in with Google" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Create account -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account?" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <Button Content="Create one" Style="{StaticResource LinkButton}" Margin="6,0,0,0"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

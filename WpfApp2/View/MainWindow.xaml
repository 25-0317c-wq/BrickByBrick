<Window x:Class="BrickByBrick.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BrickByBrick.View"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" CornerRadius="12" Padding="30" Width="350" 
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="🏢" FontSize="46" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="BrickByBrick" FontSize="28" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                <TextBlock Text="Construction Management System" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <Border Background="#F1F5F9" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#334155" FontSize="12" 
                               FontWeight="Medium" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

                <TextBlock Text="Simulate Identity Token Connection:" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>

                <Button Content="Sign In as Administrator" Command="{Binding SimulateLoginCommand}" CommandParameter="admin" Height="40" Background="#EA4335" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,4">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Sign In as Project Manager" Command="{Binding SimulateLoginCommand}" CommandParameter="manager" Height="40" Background="#4285F4" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,4">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Sign In as Field Employee" Command="{Binding SimulateLoginCommand}" CommandParameter="employee" Height="40" Background="#34A853" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,4">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Sign In as External Client" Command="{Binding SimulateLoginCommand}" CommandParameter="client" Height="40" Background="#FBBC05" Foreground="#0F172A" FontWeight="Bold" BorderThickness="0" Margin="0,4">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Separator Margin="0,15" Background="#E2E8F0"/>
                <TextBlock Text="System Framework Engine Layer v1.0.0" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>


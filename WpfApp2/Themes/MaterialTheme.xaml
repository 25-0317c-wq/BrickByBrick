<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================ -->
    <!--  SDG 9 — INDUSTRY, INNOVATION & INFRASTRUCTURE PALETTE       -->
    <!--  Primary orange (FD6925) is the OFFICIAL UN SDG 9 color.     -->
    <!--  Paired with steel/navy tones for an "infrastructure" feel.  -->
    <!-- ============================================================ -->

    <!-- Core palette -->
    <Color x:Key="Sdg9OrangeColor">#FD6925</Color>
    <Color x:Key="Sdg9OrangeDarkColor">#D9551A</Color>
    <Color x:Key="Sdg9OrangeLightColor">#FFE3D4</Color>

    <Color x:Key="SteelNavyColor">#1B2A41</Color>
    <Color x:Key="SteelNavySoftColor">#27374D</Color>
    <Color x:Key="SteelBlueGrayColor">#52688A</Color>

    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="BackgroundColor">#F4F6F9</Color>
    <Color x:Key="OutlineColor">#E2E8F0</Color>

    <Color x:Key="TextPrimaryColor">#13202F</Color>
    <Color x:Key="TextSecondaryColor">#5B6B82</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>

    <!-- Role accent colors (Material-style desaturated, not flag colors) -->
    <Color x:Key="RoleAdminColor">#C0392B</Color>
    <Color x:Key="RoleManagerColor">#1B6FC0</Color>
    <Color x:Key="RoleEmployeeColor">#1E8A5F</Color>
    <Color x:Key="RoleClientColor">#B8860B</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Sdg9OrangeBrush" Color="{StaticResource Sdg9OrangeColor}"/>
    <SolidColorBrush x:Key="Sdg9OrangeDarkBrush" Color="{StaticResource Sdg9OrangeDarkColor}"/>
    <SolidColorBrush x:Key="Sdg9OrangeLightBrush" Color="{StaticResource Sdg9OrangeLightColor}"/>

    <SolidColorBrush x:Key="SteelNavyBrush" Color="{StaticResource SteelNavyColor}"/>
    <SolidColorBrush x:Key="SteelNavySoftBrush" Color="{StaticResource SteelNavySoftColor}"/>
    <SolidColorBrush x:Key="SteelBlueGrayBrush" Color="{StaticResource SteelBlueGrayColor}"/>

    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource OutlineColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource TextOnPrimaryColor}"/>

    <SolidColorBrush x:Key="RoleAdminBrush" Color="{StaticResource RoleAdminColor}"/>
    <SolidColorBrush x:Key="RoleManagerBrush" Color="{StaticResource RoleManagerColor}"/>
    <SolidColorBrush x:Key="RoleEmployeeBrush" Color="{StaticResource RoleEmployeeColor}"/>
    <SolidColorBrush x:Key="RoleClientBrush" Color="{StaticResource RoleClientColor}"/>

    <!-- ============================================================ -->
    <!--  ELEVATION (Material-style layered drop shadows)             -->
    <!-- ============================================================ -->

    <Style x:Key="ElevationCard1" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" Direction="270" ShadowDepth="3"
                                   Color="#1B2A41" Opacity="0.14"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!--  TYPOGRAPHY SCALE                                             -->
    <!-- ============================================================ -->

    <Style x:Key="HeadlineText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource SteelNavyBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
    </Style>

    <Style x:Key="SubtitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="SectionLabelText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SteelBlueGrayBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- ============================================================ -->
    <!--  MATERIAL ROLE BUTTON                                         -->
    <!--  Real ControlTemplate so CornerRadius actually applies,       -->
    <!--  with hover/pressed states emulating Material elevation.      -->
    <!-- ============================================================ -->

    <Style x:Key="MaterialRoleButton" TargetType="Button">
        <Setter Property="Height" Value="46"/>
        <Setter Property="Margin" Value="0,5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnPrimaryBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="16,0,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Direction="270"
                                               ShadowDepth="1" Color="#13202F" Opacity="0.18"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.92"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.8"/>
                            <Setter TargetName="RootBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="3" Direction="270"
                                                       ShadowDepth="0" Color="#13202F" Opacity="0.18"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!--  STATUS BANNER (bound to StatusMessage)                       -->
    <!-- ============================================================ -->

    <Style x:Key="StatusBannerBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Sdg9OrangeLightBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="BorderBrush" Value="{StaticResource Sdg9OrangeBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
    </Style>

</ResourceDictionary>
